{
  "name": "podcast-hub",
  "private": true,
  "version": "0.1.0",
  "description": "Podcast Hub v1 monorepo",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @podcast-hub/api db:migrate",
    "db:seed": "pnpm --filter @podcast-hub/api db:seed"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
